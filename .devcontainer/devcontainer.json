{
  "name": "Java Banking System",
  "image": "mcr.microsoft.com/devcontainers/java:1-17",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": true,
      "installGradle": false
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y mysql-server && sudo service mysql start && sleep 10 && sudo mysql -e \"CREATE DATABASE IF NOT EXISTS bankdb;\"",
  "postStartCommand": "sudo service mysql start",
  "forwardPorts": [3306],
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.java",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test"
      ]
    }
  },
  "remoteEnv": {
    "DB_URL": "jdbc:mysql://localhost:3306/bankdb",
    "DB_USERNAME": "root", 
    "DB_PASSWORD": ""
  }
}